<Window x:Class="EasyParking.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:EasyParking.App.ViewModels"
        xmlns:conv="clr-namespace:EasyParking.App.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance vm:MainViewModel}"
        Title="EasyParking AG – Parkhaus-Verwaltung"
        Height="900" Width="1500" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis" />
        <conv:NotNullToVisibilityConverter x:Key="NotNullVis" />
    </Window.Resources>
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#1F4E79" Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="EasyParking AG" FontSize="20" FontWeight="Bold" Foreground="White" />
                <TextBlock Text="   Prototyp" FontSize="14" Foreground="#BDD7EE" VerticalAlignment="Center" Margin="10,4,0,0" />
            </StackPanel>
        </Border>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding Meldung}" />
            </StatusBarItem>
        </StatusBar>

        <TabControl Margin="6">
            <TabItem Header="Übersicht &amp; Schranken">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <DockPanel Margin="8">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Parkhaus:" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <ComboBox ItemsSource="{Binding Parkhaeuser}"
                                      SelectedItem="{Binding AktuellesParkhaus}"
                                      DisplayMemberPath="Titel" MinWidth="260" />
                            <Button Content="Aktualisieren" Command="{Binding AktualisierenCommand}" Style="{StaticResource ActionButton}" Margin="16,0,0,0" />
                        </StackPanel>

                        <TextBlock Text="{Binding AktuellesParkhausTitel}" Style="{StaticResource Header}" DockPanel.Dock="Top" />

                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding AktuellesParkhaus.Stockwerke}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:StockwerkViewModel}">
                                        <Border BorderBrush="#CCC" BorderThickness="1" Margin="0,6" Padding="8" CornerRadius="3">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Zusammenfassung}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6" />
                                                <ItemsControl ItemsSource="{Binding Parkplaetze}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel Orientation="Horizontal" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type vm:ParkplatzViewModel}">
                                                            <Border Width="80" Height="60" Margin="3" CornerRadius="4"
                                                                    Background="{Binding Farbe}">
                                                                <TextBlock Text="{Binding StatusText}" Foreground="White"
                                                                           TextAlignment="Center" VerticalAlignment="Center"
                                                                           FontSize="10" TextWrapping="Wrap" Padding="4" />
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>

                    <DockPanel Grid.Column="1" Margin="8" LastChildFill="True">
                        <Border DockPanel.Dock="Top" BorderBrush="#CCC" BorderThickness="1" Padding="10" Margin="0,0,0,8" CornerRadius="3">
                            <StackPanel>
                                <TextBlock Text="Eingangsschranke" Style="{StaticResource Header}" />
                                <Button Content="Gelegenheitsnutzer  ⇒  Ticket" Command="{Binding EingangGelegenheitCommand}" Style="{StaticResource ActionButton}" Background="#70AD47" Foreground="White" />
                                <Separator Margin="0,8" />
                                <TextBlock Text="Dauermieter-Code:" />
                                <TextBox Text="{Binding DauermieterCode, UpdateSourceTrigger=PropertyChanged}" Padding="4" Margin="0,4" />
                                <Button Content="Code prüfen &amp; einfahren" Command="{Binding EingangDauermieterCommand}" Style="{StaticResource ActionButton}" Background="#5B9BD5" Foreground="White" />
                            </StackPanel>
                        </Border>

                        <Border DockPanel.Dock="Top" BorderBrush="#CCC" BorderThickness="1" Padding="10" Margin="0,0,0,8" CornerRadius="3">
                            <StackPanel>
                                <TextBlock Text="Ausgangsschranke" Style="{StaticResource Header}" />
                                <TextBlock Text="Offene Tickets:" />
                                <ListBox ItemsSource="{Binding OffeneTickets}" SelectedItem="{Binding GewaehltesOffenesTicket}"
                                         DisplayMemberPath="Anzeige" Height="120" FontFamily="Consolas" Margin="0,4" />
                                <Button Content="Ticket entwerten &amp; ausfahren" Command="{Binding AusgangCommand}" Style="{StaticResource ActionButton}" Background="#C00000" Foreground="White" />
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="#CCC" BorderThickness="1" Padding="10" CornerRadius="3">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <Grid Visibility="{Binding LetztesTicket, Converter={StaticResource NotNullVis}}"
                                      DataContext="{Binding LetztesTicket}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Titel}" Style="{StaticResource Header}" />
                                        <Grid Margin="0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Ticket-Nr.:" FontWeight="SemiBold" />
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TicketNummer}" />
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Parkhaus:" FontWeight="SemiBold" />
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Parkhaus}" />
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Platz:" FontWeight="SemiBold" />
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PlatzInfo}" />
                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Kategorie:" FontWeight="SemiBold" />
                                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Kategorie}" />
                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Eingang:" FontWeight="SemiBold" />
                                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Eingang}" />
                                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Ausgang:" FontWeight="SemiBold" Visibility="{Binding IstAusgang, Converter={StaticResource BoolVis}}" />
                                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Ausgang}" Visibility="{Binding IstAusgang, Converter={StaticResource BoolVis}}" />
                                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Betrag:" FontWeight="SemiBold" Visibility="{Binding IstAusgang, Converter={StaticResource BoolVis}}" />
                                            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding Betrag}" FontWeight="Bold" Visibility="{Binding IstAusgang, Converter={StaticResource BoolVis}}" />
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </ScrollViewer>
                        </Border>
                    </DockPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Dauermieter" DataContext="{Binding Dauermieter}">
                <DockPanel Margin="8">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Parkhaus:" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <ComboBox ItemsSource="{Binding Parkhaeuser}" SelectedItem="{Binding GewaehltesParkhaus}"
                                  DisplayMemberPath="Titel" MinWidth="260" />
                        <Button Content="Neu" Command="{Binding NeuCommand}" Style="{StaticResource ActionButton}" Margin="16,0,0,0" />
                        <Button Content="Bearbeiten" Command="{Binding BearbeitenCommand}" Style="{StaticResource ActionButton}" />
                        <Button Content="Löschen" Command="{Binding LoeschenCommand}" Style="{StaticResource ActionButton}" />
                        <Button Content="Monatsmiete CHF 200 erfassen" Command="{Binding ZahlungErfassenCommand}" Style="{StaticResource ActionButton}" Margin="16,0,0,0" />
                        <Button Content="Aktualisieren" Command="{Binding AktualisierenCommand}" Style="{StaticResource ActionButton}" />
                    </StackPanel>

                    <Border DockPanel.Dock="Bottom" BorderBrush="#CCC" BorderThickness="1" Padding="10" Margin="0,8,0,0" CornerRadius="3"
                            Visibility="{Binding BearbeitenAktiv, Converter={StaticResource BoolVis}}">
                        <StackPanel>
                            <TextBlock Text="Dauermieter bearbeiten / anlegen" Style="{StaticResource Header}" />
                            <UniformGrid Columns="4" Rows="2" Margin="0,4">
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Code" />
                                    <TextBox Text="{Binding EditCode, UpdateSourceTrigger=PropertyChanged}" Padding="4" />
                                </StackPanel>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Vorname" />
                                    <TextBox Text="{Binding EditVorname, UpdateSourceTrigger=PropertyChanged}" Padding="4" />
                                </StackPanel>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Nachname" />
                                    <TextBox Text="{Binding EditNachname, UpdateSourceTrigger=PropertyChanged}" Padding="4" />
                                </StackPanel>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Parkhaus" />
                                    <ComboBox ItemsSource="{Binding Parkhaeuser}" SelectedItem="{Binding EditParkhaus}" DisplayMemberPath="Titel" />
                                </StackPanel>
                                <StackPanel Grid.ColumnSpan="2" Margin="0,8,8,0">
                                    <TextBlock Text="Parkplatz (frei + aktuell zugewiesener)" />
                                    <ComboBox ItemsSource="{Binding VerfuegbarePlaetze}" SelectedItem="{Binding EditParkplatz}" DisplayMemberPath="Anzeige" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,16,0,0" Grid.ColumnSpan="2">
                                    <Button Content="Speichern" Command="{Binding EditSpeichernCommand}" Style="{StaticResource ActionButton}" Background="#1F4E79" Foreground="White" />
                                    <Button Content="Abbrechen" Command="{Binding AbbrechenCommand}" Style="{StaticResource ActionButton}" />
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <Border DockPanel.Dock="Bottom" BorderBrush="#CCC" BorderThickness="1" Padding="10" Margin="0,8,0,0" CornerRadius="3"
                            Visibility="{Binding Meldung, Converter={StaticResource NotNullVis}}">
                        <TextBlock Text="{Binding Meldung}" TextWrapping="Wrap" FontFamily="Consolas">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#2E7D32" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IstFehler}" Value="True">
                                            <Setter Property="Foreground" Value="#C62828" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <DataGrid ItemsSource="{Binding AktuelleMieter}" SelectedItem="{Binding GewaehlterMieter}"
                              AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal" AlternatingRowBackground="#F5F5F5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="120" />
                            <DataGridTextColumn Header="Name" Binding="{Binding Anzeigename}" Width="260" />
                            <DataGridTextColumn Header="Fester Platz" Binding="{Binding PlatzInfo}" Width="180" />
                            <DataGridTextColumn Header="Letzte Zahlung" Binding="{Binding LetzteZahlung}" Width="200" />
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="Statistik / Umsatz" DataContext="{Binding Statistik}">
                <DockPanel Margin="8">
                    <Border DockPanel.Dock="Top" BorderBrush="#CCC" BorderThickness="1" Padding="10" Margin="0,0,0,8" CornerRadius="3">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Jahr:" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBox Text="{Binding Jahr, UpdateSourceTrigger=PropertyChanged}" Width="70" Padding="4" />
                            <TextBlock Text="Monat:" VerticalAlignment="Center" Margin="12,0,6,0" />
                            <TextBox Text="{Binding Monat, UpdateSourceTrigger=PropertyChanged}" Width="50" Padding="4" />
                            <TextBlock Text="Parkhaus:" VerticalAlignment="Center" Margin="12,0,6,0" />
                            <ComboBox ItemsSource="{Binding Parkhaeuser}" SelectedItem="{Binding GewaehltesParkhaus}" DisplayMemberPath="Titel" Width="200" />
                            <TextBlock Text="Gruppe:" VerticalAlignment="Center" Margin="12,0,6,0" />
                            <ComboBox ItemsSource="{Binding Gruppen}" SelectedItem="{Binding GewaehlteGruppe}" Width="160" />
                            <Button Content="Berechnen" Command="{Binding BerechnenCommand}" Style="{StaticResource ActionButton}" Margin="16,0,0,0" />
                        </StackPanel>
                    </Border>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Monatsumsatz" Style="{StaticResource Header}" Margin="0,4" />
                        <DataGrid Grid.Row="1" ItemsSource="{Binding MonatsUmsatz}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Periode" Binding="{Binding Titel}" Width="100" />
                                <DataGridTextColumn Header="Gelegenheitsnutzer" Binding="{Binding Gelegenheit, StringFormat=CHF {0:F2}}" Width="180" />
                                <DataGridTextColumn Header="Dauermieter" Binding="{Binding Dauermiete, StringFormat=CHF {0:F2}}" Width="180" />
                                <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=CHF {0:F2}}" Width="180" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock Grid.Row="2" Text="Jahresumsatz (monatsweise)" Style="{StaticResource Header}" Margin="0,12,0,4" />
                        <DataGrid Grid.Row="3" ItemsSource="{Binding JahresUmsatz}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" AlternatingRowBackground="#F5F5F5">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Periode" Binding="{Binding Titel}" Width="100" />
                                <DataGridTextColumn Header="Gelegenheitsnutzer" Binding="{Binding Gelegenheit, StringFormat=CHF {0:F2}}" Width="180" />
                                <DataGridTextColumn Header="Dauermieter" Binding="{Binding Dauermiete, StringFormat=CHF {0:F2}}" Width="180" />
                                <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=CHF {0:F2}}" Width="180" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </DockPanel>
            </TabItem>

            <TabItem Header="Parkhaus-Verwaltung" DataContext="{Binding ParkhausVerwaltung}">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <DockPanel Grid.Column="0" Margin="0,0,8,0">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                            <Button Content="Neu" Command="{Binding NeuCommand}" Style="{StaticResource ActionButton}" MinWidth="80" />
                            <Button Content="Löschen" Command="{Binding LoeschenCommand}" Style="{StaticResource ActionButton}" MinWidth="80" />
                        </StackPanel>
                        <ListBox ItemsSource="{Binding Parkhaeuser}" SelectedItem="{Binding GewaehltesParkhaus}" DisplayMemberPath="Anzeige" />
                    </DockPanel>

                    <DockPanel Grid.Column="1" IsEnabled="{Binding KannBearbeiten}">
                        <Border DockPanel.Dock="Top" BorderBrush="#CCC" BorderThickness="1" Padding="10" Margin="0,0,0,8" CornerRadius="3">
                            <StackPanel DataContext="{Binding GewaehltesParkhaus}">
                                <TextBlock Text="Stammdaten" Style="{StaticResource Header}" />
                                <UniformGrid Columns="3" Rows="1" Margin="0,4">
                                    <StackPanel Margin="0,0,8,0">
                                        <TextBlock Text="Name" />
                                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Padding="4" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,8,0">
                                        <TextBlock Text="Stadt" />
                                        <TextBox Text="{Binding Stadt, UpdateSourceTrigger=PropertyChanged}" Padding="4" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Gruppe" />
                                        <TextBox Text="{Binding Gruppe, UpdateSourceTrigger=PropertyChanged}" Padding="4" />
                                    </StackPanel>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Stockwerke" Style="{StaticResource Header}" VerticalAlignment="Center" />
                            <Button Content="+ Stockwerk" Command="{Binding StockwerkHinzufuegenCommand}" Style="{StaticResource ActionButton}" Margin="16,0,0,0" />
                            <Button Content="- Stockwerk" Command="{Binding StockwerkEntfernenCommand}" Style="{StaticResource ActionButton}" />
                            <Button Content="Speichern" Command="{Binding SpeichernCommand}" Style="{StaticResource ActionButton}" Background="#1F4E79" Foreground="White" Margin="16,0,0,0" />
                        </StackPanel>

                        <Border DockPanel.Dock="Bottom" BorderBrush="#CCC" BorderThickness="1" Padding="10" Margin="0,8,0,0" CornerRadius="3"
                                Visibility="{Binding Meldung, Converter={StaticResource NotNullVis}}">
                            <TextBlock Text="{Binding Meldung}" TextWrapping="Wrap" FontFamily="Consolas">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#2E7D32" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IstFehler}" Value="True">
                                                <Setter Property="Foreground" Value="#C62828" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                        <DataGrid ItemsSource="{Binding GewaehltesParkhaus.Stockwerke}" SelectedItem="{Binding GewaehltesStockwerk}"
                                  AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column"
                                  AlternatingRowBackground="#F5F5F5">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Nummer" Binding="{Binding Nummer, UpdateSourceTrigger=PropertyChanged}" Width="100" />
                                <DataGridTextColumn Header="Bezeichnung" Binding="{Binding Bezeichnung, UpdateSourceTrigger=PropertyChanged}" Width="220" />
                                <DataGridTextColumn Header="Anzahl Parkplätze" Binding="{Binding AnzahlPlaetze, UpdateSourceTrigger=PropertyChanged}" Width="160" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Feiertage" DataContext="{Binding FeiertagVerwaltung}">
                <DockPanel Margin="8">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Neu" Command="{Binding NeuCommand}" Style="{StaticResource ActionButton}" />
                        <Button Content="Ausgewählt entfernen" Command="{Binding EntfernenCommand}" Style="{StaticResource ActionButton}" />
                        <Button Content="Speichern (alle)" Command="{Binding SpeichernCommand}" Style="{StaticResource ActionButton}" Background="#1F4E79" Foreground="White" Margin="16,0,0,0" />
                        <Button Content="Neu laden" Command="{Binding NeuladenCommand}" Style="{StaticResource ActionButton}" />
                    </StackPanel>

                    <Border DockPanel.Dock="Bottom" BorderBrush="#CCC" BorderThickness="1" Padding="10" Margin="0,8,0,0" CornerRadius="3"
                            Visibility="{Binding Meldung, Converter={StaticResource NotNullVis}}">
                        <TextBlock Text="{Binding Meldung}" TextWrapping="Wrap" FontFamily="Consolas">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#2E7D32" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IstFehler}" Value="True">
                                            <Setter Property="Foreground" Value="#C62828" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <DataGrid ItemsSource="{Binding Feiertage}" SelectedItem="{Binding GewaehlterFeiertag}"
                              AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column" AlternatingRowBackground="#F5F5F5">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Datum" Width="160">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <DatePicker SelectedDate="{Binding Datum, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Bezeichnung" Binding="{Binding Bezeichnung, UpdateSourceTrigger=PropertyChanged}" Width="300" />
                            <DataGridTemplateColumn Header="Parkhaus (leer = alle)" Width="250">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding DataContext.ParkhausOptionen, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                  SelectedItem="{Binding Parkhaus, UpdateSourceTrigger=PropertyChanged}"
                                                  DisplayMemberPath="Titel" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="Tarifverwaltung" DataContext="{Binding Tarife}">
                <DockPanel Margin="8">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Parkhaus:" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <ComboBox ItemsSource="{Binding Parkhaeuser}" SelectedItem="{Binding GewaehltesParkhaus}"
                                  DisplayMemberPath="Titel" MinWidth="260" />
                        <Button Content="Neu laden" Command="{Binding NeuladenCommand}" Style="{StaticResource ActionButton}" Margin="16,0,0,0" />
                        <Button Content="Speichern" Command="{Binding SpeichernCommand}" Style="{StaticResource ActionButton}"
                                Background="#1F4E79" Foreground="White" IsEnabled="{Binding KannSpeichern}" />
                    </StackPanel>

                    <Border DockPanel.Dock="Bottom" BorderBrush="#CCC" BorderThickness="1" Padding="10" Margin="0,8,0,0" CornerRadius="3">
                        <StackPanel>
                            <TextBlock Text="Neue Tarifzeile hinzufügen" Style="{StaticResource Header}" />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Typ:" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <ComboBox ItemsSource="{Binding Source={x:Static vm:TarifVerwaltungViewModel.TarifTypen}}"
                                          SelectedItem="{Binding NeuTyp}" Width="200" />
                                <TextBlock Text="Ab Stunde:" VerticalAlignment="Center" Margin="12,0,6,0" />
                                <TextBox Text="{Binding NeuStart, UpdateSourceTrigger=PropertyChanged}" Width="60" Padding="4" />
                                <TextBlock Text="Bis Stunde:" VerticalAlignment="Center" Margin="12,0,6,0" />
                                <TextBox Text="{Binding NeuEnd, UpdateSourceTrigger=PropertyChanged}" Width="60" Padding="4" />
                                <TextBlock Text="CHF/Std.:" VerticalAlignment="Center" Margin="12,0,6,0" />
                                <TextBox Text="{Binding NeuPreis, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}" Width="80" Padding="4" />
                                <Button Content="Hinzufügen" Command="{Binding HinzufuegenCommand}" Style="{StaticResource ActionButton}" Margin="16,0,0,0" />
                                <Button Content="Ausgewählt entfernen" Command="{Binding EntfernenCommand}" Style="{StaticResource ActionButton}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border DockPanel.Dock="Bottom" BorderBrush="#CCC" BorderThickness="1" Padding="10" Margin="0,8,0,0" CornerRadius="3"
                            Visibility="{Binding Meldung, Converter={StaticResource NotNullVis}}">
                        <TextBlock Text="{Binding Meldung}" TextWrapping="Wrap" FontFamily="Consolas">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#2E7D32" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IstFehler}" Value="True">
                                            <Setter Property="Foreground" Value="#C62828" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <DataGrid ItemsSource="{Binding Tarife}" SelectedItem="{Binding GewaehlterTarif}"
                              AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column"
                              AlternatingRowBackground="#F5F5F5">
                        <DataGrid.Columns>
                            <DataGridComboBoxColumn Header="Typ"
                                                    ItemsSource="{Binding Source={x:Static vm:TarifVerwaltungViewModel.TarifTypen}}"
                                                    SelectedItemBinding="{Binding Typ}" Width="220" />
                            <DataGridTextColumn Header="Ab Stunde" Binding="{Binding StartStunde}" Width="100" />
                            <DataGridTextColumn Header="Bis Stunde" Binding="{Binding EndStunde}" Width="100" />
                            <DataGridTextColumn Header="CHF / Std." Binding="{Binding PreisProStunde, StringFormat=F2}" Width="140" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="Zeitauswertung" DataContext="{Binding ZeitAuswertung}">
                <DockPanel Margin="8">
                    <Border DockPanel.Dock="Top" BorderBrush="#CCC" BorderThickness="1" Padding="10" Margin="0,0,0,8" CornerRadius="3">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Von:" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <DatePicker SelectedDate="{Binding Von}" />
                            <TextBlock Text="Bis:" VerticalAlignment="Center" Margin="12,0,6,0" />
                            <DatePicker SelectedDate="{Binding Bis}" />
                            <TextBlock Text="Kategorie:" VerticalAlignment="Center" Margin="12,0,6,0" />
                            <ComboBox ItemsSource="{Binding Kategorien}" SelectedItem="{Binding GewaehlteKategorie}" Width="180" />
                            <TextBlock Text="Parkhaus:" VerticalAlignment="Center" Margin="12,0,6,0" />
                            <ComboBox ItemsSource="{Binding Parkhaeuser}" SelectedItem="{Binding GewaehltesParkhaus}" DisplayMemberPath="Titel" Width="200" />
                            <Button Content="Auswerten" Command="{Binding AuswertenCommand}" Style="{StaticResource ActionButton}" Margin="16,0,0,0" />
                        </StackPanel>
                    </Border>
                    <DataGrid ItemsSource="{Binding Ergebnis}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" AlternatingRowBackground="#F5F5F5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Zeitpunkt" Binding="{Binding Zeitpunkt, StringFormat={}{0:dd.MM.yyyy HH:mm:ss}}" Width="180" />
                            <DataGridTextColumn Header="Typ" Binding="{Binding Typ}" Width="100" />
                            <DataGridTextColumn Header="Parkhaus" Binding="{Binding ParkhausName}" Width="200" />
                            <DataGridTextColumn Header="Platz" Binding="{Binding PlatzInfo}" Width="160" />
                            <DataGridTextColumn Header="Kunde" Binding="{Binding Kunde}" Width="280" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
